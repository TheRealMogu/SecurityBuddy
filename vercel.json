{
  "version": 2,
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/main.py"
    }
  ],
  "env": {
    "FLASK_ENV": "production"
  },
  "functions": {
    "main.py": {
      "runtime": "vercel-python@4",
      "maxDuration": 30
    }
  }
}
