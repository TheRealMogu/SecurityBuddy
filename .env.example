# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database

# Flask Configuration
SESSION_SECRET=your-secret-key-here
FLASK_ENV=production

# Gmail Newsletter Manager (Google OAuth — free Gmail API)
# Create an OAuth 2.0 "Web application" client in Google Cloud Console and add
# the callback URL (e.g. http://localhost:5000/gmail/callback) as an authorized
# redirect URI. In "testing" publishing mode, add your account as a test user.
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Optional: dedicated key for encrypting stored Gmail OAuth tokens at rest.
# A urlsafe-base64 32-byte Fernet key. If unset, it is derived from SESSION_SECRET.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Optional: Email notifications (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key

# Optional: SMS notifications (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number